# Frontend on port 80
:80 {
    reverse_proxy backend:3000
}

# Backend on port 8000
:8000 {
    # 1. Static Files (Admin CSS/JS)
    handle_path /static/* {
        root * /app/staticfiles
        file_server
    }

    # 2. Media Files (User Uploads)
    handle_path /media/* {
        root * /app/media
        file_server
    }

    # 3. Redirect root of 8000 to /admin/
    redir / /admin/

    # 4. All other traffic on 8000 goes to Gunicorn
    handle {
        reverse_proxy backend:8000
    }
}
