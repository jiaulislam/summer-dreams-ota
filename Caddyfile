{$DOMAIN:localhost} {
    # Compress responses for better performance
    encode zstd gzip

    # Serve static files directly via Caddy
    handle_path /static/* {
        root * /var/www/static
        file_server
    }

    # Serve media files directly via Caddy
    handle_path /media/* {
        root * /var/www/media
        file_server
    }

    # Proxy API requests to Django backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Proxy Admin requests to Django backend
    handle /admin/* {
        reverse_proxy backend:8000
    }

    # Proxy all other requests to Next.js frontend
    handle /* {
        reverse_proxy frontend:3000
    }
}
