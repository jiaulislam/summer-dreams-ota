FROM node:22-alpine AS base

# --- Stage 1: Install dependencies ---
FROM base AS deps
# libc6-compat is required for some native Node modules (like image optimization or swc)
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# HUSKY=0 prevents the Husky prepare script from crashing the build
# since there is no .git folder inside the Docker container.
RUN npm install --ignore-scripts --legacy-peer-deps


# --- Stage 2: Builder ---
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# IMPORTANT: Inject NEXT_PUBLIC variables at build time
# We declare it as an ARG so Docker Compose can pass it in
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Disable Next.js telemetry to speed up the build and save data
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build


# --- Stage 3: Final Production Image ---
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create a non-privileged user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Set the correct permission for the prerender cache
RUN mkdir .next && chown nextjs:nodejs .next

# Automatically leverage output traces to reduce image size (~150MB instead of 1GB+)
# COPY static assets
COPY --from=builder /app/public ./public

# COPY the standalone build
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
# Ensure Node listens on all network interfaces in Docker
ENV HOSTNAME="0.0.0.0"

# server.js is automatically generated by the standalone build
CMD ["node", "server.js"]
